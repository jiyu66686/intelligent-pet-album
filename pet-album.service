[Unit]
Description=Pet Album Flask Application
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/pet-photo-album/backend
Environment="PATH=/var/www/pet-photo-album/backend/venv/bin"
ExecStart=/var/www/pet-photo-album/backend/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 app:app
Restart=always

[Install]
WantedBy=multi-user.target